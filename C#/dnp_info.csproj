<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <AssemblyName>dnp_info</AssemblyName>
    <RootNamespace>Dnp</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <RuntimeIdentifiers>win-x86;win-x64;linux-x64</RuntimeIdentifiers>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="USB_RAW\**\*.cs" />
    <EmbeddedResource Remove="USB_RAW\**\*" />
    <None Remove="USB_RAW\**\*" />
    <Content Remove="USB_RAW\**\*" />
  </ItemGroup>

  <ItemGroup>
    <None Include="dll\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
    </None>
    <None Include="build\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>Never</CopyToPublishDirectory>
    </None>
  </ItemGroup>
  <ItemGroup>
    <Compile Remove="Transports/CspStatNative.cs" />
    <Compile Remove="Transports/WindowsUsbDllFilterMap.cs" />
  </ItemGroup>
</Project>
